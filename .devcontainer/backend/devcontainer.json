{
  "name": "Backend Environment",
  "dockerComposeFile": ["../../docker-compose.yml", "../../docker-compose.override.yml"],
  "service": "backend",
  "workspaceFolder": "/app",
  "runServices": ["db-postgre", "redis", "backend", "frontend"],
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    },
    "antigravity": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.python-environments",
        "meta.pyrefly"
      ]
    }
  }
}
